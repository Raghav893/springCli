# Production profile: read sensitive values from environment variables.
# Generated by springup {{ springup_version }}.
spring:
  application:
    name: {{ artifact_id }}
{% if has_postgresql or has_mysql %}
  datasource:
    url: ${DB_URL}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
{% endif %}
{% if has_data_jpa %}
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    open-in-view: false
{% endif %}
{% if has_data_redis %}
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD}
{% endif %}
{% if has_data_mongodb %}
  data:
    mongodb:
      uri: ${MONGODB_URI}
{% endif %}
{% if has_flyway %}
  flyway:
    enabled: true
    locations: classpath:db/migration
{% endif %}

server:
  port: ${PORT:8080}
  shutdown: graceful

management:
{% if has_actuator %}
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
{% endif %}
  endpoint:
    health:
      show-details: when_authorized

logging:
  level:
    {{ package_name }}: INFO
    root: WARN
