# Dev profile: local development defaults.
# Generated by springup {{ springup_version }}.
spring:
  application:
    name: {{ artifact_id }}
{% if has_postgresql %}
  datasource:
    url: jdbc:postgresql://localhost:5432/{{ artifact_id | replace('-', '_') }}
    username: app
    password: app
{% elif has_mysql %}
  datasource:
    url: jdbc:mysql://localhost:3306/{{ artifact_id | replace('-', '_') }}
    username: app
    password: app
{% elif has_data_jpa %}
  datasource:
    url: jdbc:h2:mem:devdb
    username: sa
    password:
  h2:
    console:
      enabled: true
      path: /h2-console
{% endif %}
{% if has_data_jpa %}
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
{% endif %}
{% if has_data_redis %}
  data:
    redis:
      host: localhost
      port: 6379
{% endif %}
{% if has_data_mongodb %}
  data:
    mongodb:
      uri: mongodb://app:app@localhost:27017/{{ artifact_id | replace('-', '_') }}?authSource=admin
{% endif %}
{% if has_flyway %}
  flyway:
    enabled: true
    locations: classpath:db/migration
{% endif %}

server:
  port: 8080

logging:
  level:
    {{ package_name }}: DEBUG
    org.springframework.web: DEBUG
