# Multi-stage build for a Gradle-based Spring Boot service.
# Generated by springup {{ springup_version }}.
#
# Build:
#   docker build -t {{ artifact_id }}:latest .
# Run:
#   docker run --rm -p 8080:8080 {{ artifact_id }}:latest

# ---------- Build stage ----------
FROM gradle:8-jdk{{ java_version }} AS build
WORKDIR /workspace
COPY settings.gradle* build.gradle* build.gradle.kts* settings.gradle.kts* ./
COPY gradle ./gradle
COPY gradlew ./
RUN ./gradlew --version > /dev/null 2>&1 || true
COPY src ./src
RUN ./gradlew bootJar -x test --no-daemon

# ---------- Runtime stage ----------
FROM eclipse-temurin:{{ java_version }}-jre AS runtime
WORKDIR /app
{% if packaging == "war" %}
RUN mkdir -p /app/wars
COPY --from=build /workspace/build/libs/*.war /app/wars/app.war
ENTRYPOINT ["java", "-jar", "/app/wars/app.war"]
{% else %}
COPY --from=build /workspace/build/libs/*-SNAPSHOT.jar /app/app.jar
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
{% endif %}

EXPOSE 8080
{% if has_actuator %}
HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8080/actuator/health | grep -q '"status":"UP"' || exit 1
{% else %}
HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8080/api/health | grep -q '"status":"UP"' || exit 1
{% endif %}
