# Docker Compose for {{ artifact_id }}.
# Generated by springup {{ springup_version }}.
#
# Usage:
#   docker compose up --build
#
# The app service is always defined. Database / cache services are added when the matching
# Initializr dependency was selected at scaffold time.

services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ artifact_id }}:latest
    container_name: {{ artifact_id }}
    ports:
      - "8080:8080"
    environment:
      SPRING_PROFILES_ACTIVE: ${SPRING_PROFILES_ACTIVE:-dev}
{% if has_postgresql or has_mysql or has_data_redis or has_data_mongodb %}
    depends_on:
{% if has_postgresql %}
      postgres:
        condition: service_healthy
{% endif %}
{% if has_mysql %}
      mysql:
        condition: service_healthy
{% endif %}
{% if has_data_redis %}
      redis:
        condition: service_started
{% endif %}
{% if has_data_mongodb %}
      mongo:
        condition: service_started
{% endif %}
{% endif %}
{% if has_postgresql %}

  postgres:
    image: postgres:16-alpine
    container_name: {{ artifact_id }}-postgres
    environment:
      POSTGRES_DB: {{ artifact_id | replace('-', '_') }}
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U app"]
      interval: 5s
      timeout: 3s
      retries: 10
{% endif %}
{% if has_mysql %}

  mysql:
    image: mysql:8
    container_name: {{ artifact_id }}-mysql
    environment:
      MYSQL_DATABASE: {{ artifact_id | replace('-', '_') }}
      MYSQL_USER: app
      MYSQL_PASSWORD: app
      MYSQL_ROOT_PASSWORD: root
    ports:
      - "3306:3306"
    volumes:
      - mysql-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 3s
      retries: 10
{% endif %}
{% if has_data_redis %}

  redis:
    image: redis:7-alpine
    container_name: {{ artifact_id }}-redis
    ports:
      - "6379:6379"
{% endif %}
{% if has_data_mongodb %}

  mongo:
    image: mongo:7
    container_name: {{ artifact_id }}-mongo
    environment:
      MONGO_INITDB_ROOT_USERNAME: app
      MONGO_INITDB_ROOT_PASSWORD: app
    ports:
      - "27017:27017"
    volumes:
      - mongo-data:/data/db
{% endif %}
{% if has_postgresql or has_mysql or has_data_mongodb %}

volumes:
{% if has_postgresql %}
  postgres-data:
{% endif %}
{% if has_mysql %}
  mysql-data:
{% endif %}
{% if has_data_mongodb %}
  mongo-data:
{% endif %}
{% endif %}
