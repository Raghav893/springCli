# Multi-stage build for a Maven-based Spring Boot service.
# Generated by springup {{ springup_version }}.
#
# Build:
#   docker build -t {{ artifact_id }}:latest .
# Run:
#   docker run --rm -p 8080:8080 {{ artifact_id }}:latest

# ---------- Build stage ----------
FROM maven:3.9-eclipse-temurin-{{ java_version }} AS build
WORKDIR /workspace
COPY pom.xml .
RUN mvn -B -q dependency:go-offline
COPY src ./src
RUN mvn -B -q clean package -DskipTests

# ---------- Runtime stage ----------
FROM eclipse-temurin:{{ java_version }}-jre AS runtime
WORKDIR /app
{% if packaging == "war" %}
# WAR deployment: copy WAR into a Tomcat-based image instead. For demo purposes we still run
# the executable WAR via spring-boot:run-compatible entrypoint.
RUN mkdir -p /app/wars
COPY --from=build /workspace/target/*.war /app/wars/app.war
ENTRYPOINT ["java", "-jar", "/app/wars/app.war"]
{% else %}
COPY --from=build /workspace/target/*-SNAPSHOT.jar /app/app.jar
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
{% endif %}

EXPOSE 8080
{% if has_actuator %}
HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8080/actuator/health | grep -q '"status":"UP"' || exit 1
{% else %}
HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8080/api/health | grep -q '"status":"UP"' || exit 1
{% endif %}
