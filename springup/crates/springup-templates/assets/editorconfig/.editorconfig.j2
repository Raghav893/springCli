# EditorConfig — keep editors consistent across contributors.
# Generated by springup {{ springup_version }}.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,xml,html,css,js,ts}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
