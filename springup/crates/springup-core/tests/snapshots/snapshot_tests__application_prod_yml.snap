# Production profile: read sensitive values from environment variables.
# Generated by springup 0.1.0.
spring:
  application:
    name: demo

  datasource:
    url: ${DB_URL}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}


  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    open-in-view: false





server:
  port: ${PORT:8080}
  shutdown: graceful

management:

  endpoint:
    health:
      show-details: when_authorized

logging:
  level:
    com.example.demo: INFO
    root: WARN
