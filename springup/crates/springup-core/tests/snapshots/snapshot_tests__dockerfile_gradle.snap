# Multi-stage build for a Gradle-based Spring Boot service.
# Generated by springup 0.1.0.
#
# Build:
#   docker build -t demo:latest .
# Run:
#   docker run --rm -p 8080:8080 demo:latest

# ---------- Build stage ----------
FROM gradle:8-jdk21 AS build
WORKDIR /workspace
COPY settings.gradle* build.gradle* build.gradle.kts* settings.gradle.kts* ./
COPY gradle ./gradle
COPY gradlew ./
RUN ./gradlew --version > /dev/null 2>&1 || true
COPY src ./src
RUN ./gradlew bootJar -x test --no-daemon

# ---------- Runtime stage ----------
FROM eclipse-temurin:21-jre AS runtime
WORKDIR /app

COPY --from=build /workspace/build/libs/*-SNAPSHOT.jar /app/app.jar
ENTRYPOINT ["java", "-jar", "/app/app.jar"]


EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8080/api/health | grep -q '"status":"UP"' || exit 1
